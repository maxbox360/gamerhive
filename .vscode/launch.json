{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Django: Run Server",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/manage.py",
      "args": ["runserver", "0.0.0.0:8000", "--noreload"],
      "django": true,
      "env": {
        "PYTHONPATH": "/app",
        "DJANGO_SETTINGS_MODULE": "gamerhive.settings"
      },
      "justMyCode": false
    },
    {
      "name": "Django: Run Server (with reload)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/manage.py",
      "args": ["runserver", "0.0.0.0:8000"],
      "django": true,
      "env": {
        "PYTHONPATH": "/app",
        "DJANGO_SETTINGS_MODULE": "gamerhive.settings"
      },
      "justMyCode": false
    },
    {
      "name": "Django: Shell",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/manage.py",
      "args": ["shell"],
      "django": true,
      "env": {
        "PYTHONPATH": "/app",
        "DJANGO_SETTINGS_MODULE": "gamerhive.settings"
      },
      "justMyCode": false
    },
    {
      "name": "Django: Migrate",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/manage.py",
      "args": ["migrate"],
      "django": true,
      "env": {
        "PYTHONPATH": "/app",
        "DJANGO_SETTINGS_MODULE": "gamerhive.settings"
      },
      "justMyCode": false
    },
    {
      "name": "Django: Run Tests",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/manage.py",
      "args": ["test"],
      "django": true,
      "env": {
        "PYTHONPATH": "/app",
        "DJANGO_SETTINGS_MODULE": "gamerhive.settings"
      },
      "justMyCode": false
    },
    {
      "name": "Python: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ]
}

